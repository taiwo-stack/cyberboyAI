# CyberBoyAI — Backend Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Threat Intelligence Feeds ─────────────────────────────────────────────────
ABUSEIPDB_API_KEY=your-abuseipdb-key
OTX_API_KEY=your-alienvault-otx-key

# ── Google Safe Browsing API ───────────────────────────────────────────────────
# Free tier: 10,000 requests/day. No billing required.
# Setup steps:
#   1. Go to https://console.cloud.google.com
#   2. Create a project (or use an existing one)
#   3. Navigate to "APIs & Services" → "Library"
#   4. Search for "Safe Browsing API" and click Enable
#   5. Go to "APIs & Services" → "Credentials" → "Create Credentials" → "API Key"
#   6. Paste the key below.
# If left blank, the Safe Browsing check is silently skipped (system still works).
GOOGLE_SAFE_BROWSING_API_KEY=

# ── API Security ──────────────────────────────────────────────────────────────
ADMIN_SECRET_KEY=your-secret-admin-key
ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ── Residential Proxy (Anti-Cloaking Layer) ───────────────────────────────────
# Set PROXY_ENABLED=true and fill in credentials from your residential proxy
# provider to enable ASN-based cloaking detection defeat.
#
# Supported providers:
#   brightdata  → https://brightdata.com  (formerly Luminati)
#   oxylabs     → https://oxylabs.io
#   smartproxy  → https://smartproxy.com
#   custom      → Any SOCKS5/HTTP proxy using user:pass@host:port format
#
# For Bright Data:
#   PROXY_HOST=brd.superproxy.io
#   PROXY_PORT=22225
#   PROXY_USERNAME=brd-customer-XXXXXXX-zone-residential
#   PROXY_PASSWORD=your-zone-password
#
# For Oxylabs:
#   PROXY_HOST=pr.oxylabs.io
#   PROXY_PORT=7777
#   PROXY_USERNAME=customer-YOURUSER
#   PROXY_PASSWORD=your-password
#
# For Smartproxy:
#   PROXY_HOST=gate.smartproxy.com
#   PROXY_PORT=7000
#   PROXY_USERNAME=your-username
#   PROXY_PASSWORD=your-password

PROXY_ENABLED=false
PROXY_PROVIDER=brightdata
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=
PROXY_COUNTRY=ng
